{
  "name": "contributte/thepay",
  "description": "ThePay library - nette extension",
  "keywords": [
    "the pay",
    "nette",
    "extension"
  ],
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ext-soap": "*",
    "contributte/thepay-api": "^4.0.0",
    "nette/application": "^3.2.0",
    "nette/di": "^3.2.0",
    "nette/http": "^3.3.0"
  },
  "require-dev": {
    "contributte/phpstan": "~0.2.0",
    "contributte/qa": "~0.4.0",
    "contributte/tester": "~0.3.0"
  },
  "autoload": {
    "psr-4": {
      "Contributte\\ThePay\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "v4.2.x-dev"
    }
  }
}
