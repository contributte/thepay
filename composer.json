{
  "name": "contributte/thepay",
  "description": "ThePay library - nette extension",
  "keywords": [
    "the pay",
    "nette",
    "extension"
  ],
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "nette/di": "^3.2.5",
    "nette/schema": "^1.3.0",
    "thepay/api-client": "^2.0.0"
  },
  "require-dev": {
    "contributte/phpstan": "~0.2.0",
    "contributte/qa": "~0.4.0",
    "contributte/tester": "~0.3.0"
  },
  "autoload": {
    "psr-4": {
      "Contributte\\ThePay\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "v5.0.x-dev"
    }
  }
}
